#!/bin/sh
# brain — boot the second brain: incremental sync, then a GREEN/red health lamp.
# Idempotent: run it 100x, same state. Reattaches the index, never rebuilds.
# Run this in a terminal (PGLite is single-writer — close Claude/MCP first).

VAULT="${OBSIDIAN_VAULT:-$HOME/Obsidian Vault}"
VOICE="$VAULT/Voice Memos"
STAMP="$HOME/.gbrain/last-boot"
G="OK "; R="XX "; W="~~ "; ok=1

# 1. vault reachable
if [ -d "$VAULT" ]; then l_vault="$G vault reachable"; vault_ok=1; else l_vault="$R vault MISSING ($VAULT)"; ok=0; vault_ok=0; fi

# 2. incremental sync of ALL brain sources (advisory: recall works even if deferred).
#    Single-writer: a running gbrain serve (Claude/MCP) blocks CLI sync.
blocked=0; failed=0
# auto-commit anything dropped into the vault repo, so capture = "drop a file + boot".
[ -d "$VAULT/.git" ] && ( cd "$VAULT" && git add -A >/dev/null 2>&1 && git commit -q -m "capture $(date +%F-%H%M%S)" >/dev/null 2>&1 )
# Import structurally (--no-embed) — reliable + keyword-searchable with NO key.
# Embeddings are a separate bonus layer (below), so a missing key never blocks the
# line and a green lamp always means "content is actually findable". --all covers
# every registered source, so this works for one vault source or many.
out=$(gbrain sync --all --no-pull --no-embed 2>&1); rc=$?
if [ $rc -eq 0 ]; then :
elif printf '%s' "$out" | grep -qiE 'lock|single-writer|in use|EBUSY|another'; then blocked=1
else failed=1; fi
# Semantic layer (bonus): embed any new/stale pages IF a provider key is set.
# Non-blocking — no key just means keyword-only recall, which still works.
[ "$blocked" = 0 ] && gbrain embed --stale >/dev/null 2>&1 || true
if [ "$blocked" = 1 ]; then
  l_sync="$W sync deferred — close Claude/MCP and re-run to pull in new captures"
elif [ "$failed" = 1 ]; then
  l_sync="$R sync error (run: gbrain sync --all --no-embed)"
else
  date +%s > "$STAMP"; l_sync="$G sync ok"
fi

# 3. index has pages (total across every registered source)
pages=$(gbrain sources list 2>/dev/null | awk '{for(i=1;i<=NF;i++) if($i=="pages") s+=$(i-1)} END{print s+0}')
if [ -n "$pages" ] && [ "$pages" -gt 0 ] 2>/dev/null; then
  l_index="$G index: $pages pages"
else
  l_index="$R index empty (run a sync)"; ok=0
fi

# 4. search tool registered
if claude mcp list 2>/dev/null | grep -qi 'gbrain'; then
  l_mcp="$G search tool registered (MCP)"; mcp_ok=1
else
  l_mcp="$R MCP not registered (claude mcp add gbrain -- gbrain serve)"; ok=0; mcp_ok=0
fi

# freshness
age="unknown"
if [ -f "$STAMP" ]; then
  d=$(( $(date +%s) - $(cat "$STAMP") ))
  if [ "$d" -lt 60 ]; then age="just now";
  elif [ "$d" -lt 3600 ]; then age="$((d/60))m ago";
  else age="$((d/3600))h ago"; fi
fi

echo "________ brain ________"
echo "$l_vault"
echo "$l_index   (synced: $age)"
echo "$l_mcp"
echo "$l_sync"
echo "_______________________"
if [ "$ok" = 1 ]; then
  echo "READY $G  flip it on and ask."
else
  echo "NOT READY $R  fix the line(s) marked XX above."
fi

# ── emit a live-status file the rig map reads to color itself from REAL state ──
# Git-ignored by the kit's allow-list .gitignore, so it never ships. The public
# site has no such file and falls back to the default snapshot.
_emit_status() {
  vN=$([ "${vault_ok:-0}" = 1 ] && echo live || echo todo)
  gN=$([ "${pages:-0}" -gt 0 ] 2>/dev/null && echo live || echo todo)
  rN=$([ "${mcp_ok:-0}" = 1 ] && echo live || echo todo)
  rE=$([ "${mcp_ok:-0}" = 1 ] && echo g || echo r)
  printf 'window.AIOS_STATUS = { synced:"%s", nodes:{ vault:"%s", gb:"%s", tg:"%s", cc:"%s" }, edges:{ "gb->tg":"%s", "gb->cc":"%s" } };\n' \
    "$age" "$vN" "$gN" "$rN" "$rN" "$rE" "$rE"
}
for _d in "$HOME/fpm-agentic-os" "$HOME"; do
  if [ -f "$_d/rig-map.html" ] || [ -f "$_d/rig-flow.html" ]; then
    _emit_status > "$_d/aios-status.js" 2>/dev/null && echo "map status -> $_d/aios-status.js"
  fi
done
